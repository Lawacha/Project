<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <div class="container" >
      <%   for(let list of listings){ %>
        <div>
            <p><%= list.title %></p>
            <p><%= list.description %></p>
           <img src="<%= list.image.url %>" style="height: 200px; width: 200px;" alt="">
            <p>$<%= list.price %></p>
            <p><%= list.location %></p>
            <p><%= list.country %></p>

            <form action="http://localhost:8080/listings/<%= list._id %>">
                <button>Show</button>
            </form>
            <form action="http://localhost:8080/listings/<%= list._id %>/edit">
                <button>Edit</button>
            </form>
        </div>
       <%  } %>
    </div>
</body>
</html>