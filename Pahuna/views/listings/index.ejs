<% layout('../layouts/boilerplate') %>

<div class="row mt-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1" >

    <% for(let list of listings){ %>
       
        <a href="/listings/<%= list._id %>" class="list-link">
            <div class="card col" >
            <img src="<%= list.image.url %>" class="card-img-top" style="height:20rem;" alt="listing_img">
            <div class="card-img-overlay"></div>

            <div class="card-body">
                <h5 class="card-title"><b><%= list.title %></b></h5>
                <p class="card-text"><%= list.description %></p>
                <p class="card-text">$<%= list.price %></p>
                <p><%= list.location %></p>
                <p><%= list.country %></p>
              
            </div>
        </div>
        </a>
 <% } %>
</div>